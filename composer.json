{
    "name": "jooservices/xflickr-crawler",
    "description": "Standalone Laravel package for queued Flickr crawling with rate limiting and MySQL persistence.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "php85",
        "laravel",
        "laravel12",
        "flickr",
        "crawler",
        "queue",
        "jooservices"
    ],
    "authors": [
        {
            "name": "Viet Vu",
            "email": "jooservices@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/jooservices/XFlickrCrawler/issues",
        "source": "https://github.com/jooservices/XFlickrCrawler"
    },
    "require": {
        "php": "^8.5",
        "jooservices/dto": "^1.0",
        "jooservices/flickr": "^1.0",
        "jooservices/laravel-config": "^1.1",
        "laravel/framework": "^12.0"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.23",
        "captainhook/plugin-composer": "^5.3",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "JOOservices\\XFlickrCrawler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JOOservices\\XFlickrCrawler\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JOOservices\\XFlickrCrawler\\XFlickrCrawlerServiceProvider"
            ],
            "aliases": {
                "FlickrService": "JOOservices\\XFlickrCrawler\\Facades\\FlickrService"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-clover coverage.xml",
        "instructions:verify": "php tools/verify-ai-instructions-sync.php",
        "lint:pint": "vendor/bin/pint --test",
        "lint:pint:fix": "vendor/bin/pint",
        "lint:phpstan": "XDEBUG_MODE=off vendor/bin/phpstan analyse --configuration=phpstan.neon --memory-limit=512M",
        "lint:phpcs": "vendor/bin/phpcs --standard=phpcs.xml",
        "lint:phpmd": "php -d error_reporting=6143 vendor/bin/phpmd src text phpmd.xml",
        "lint:fast": [
            "@lint:pint",
            "@lint:phpcs",
            "@lint:phpstan"
        ],
        "lint": [
            "@lint:fast"
        ],
        "lint:all": [
            "@lint",
            "@lint:phpmd"
        ],
        "lint:fix": [
            "@lint:pint:fix"
        ],
        "check": [
            "@lint:all",
            "@test"
        ],
        "ci": [
            "@lint:all",
            "@test:coverage"
        ],
        "post-install-cmd": "captainhook install --force --skip-existing",
        "post-update-cmd": "captainhook install --force --skip-existing"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "captainhook/plugin-composer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
